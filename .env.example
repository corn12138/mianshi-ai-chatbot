# API
PORT=3000
WEB_ORIGIN=http://localhost:5173

# LLM mode. Leave unset or use "mock" for the default no-key experience.
# Keep this as the active default so the repo runs with zero configuration.
LLM_PROVIDER=mock

# --- Optional real-model modes (all commented out so copying this file stays in mock mode) ---

# Optional OpenAI-compatible mode.
# Works with OpenAI, third-party relay gateways (One API / LiteLLM / OpenRouter),
# and internal company gateways: just point OPENAI_BASE_URL at any /chat/completions endpoint.
# See docs/delivery/model-gateway.md for per-gateway examples.
# LLM_PROVIDER=openai-compatible
# OPENAI_PROVIDER_LABEL=Company Gateway
# OPENAI_BASE_URL=https://llm-gateway.example.com/v1
# OPENAI_MODEL=company-chat-model
# OPENAI_API_KEY=replace-with-your-key

# Optional DeepSeek mode. Keep real keys only in local .env.
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=replace-with-your-key
# DeepSeek_KEY=replace-with-your-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_THINKING=disabled

# --- Real-model resilience (only affects deepseek / openai-compatible modes) ---

# Timeout for real LLM HTTP calls in milliseconds. Default is 15000.
# LLM_REQUEST_TIMEOUT_MS=15000

# When "true", a failed real-model call gracefully falls back to mock for that turn
# instead of returning an error. Off by default: the default behavior is to fail loudly.
# LLM_FALLBACK_TO_MOCK=true

# --- Security and concurrency hardening (defaults keep local demo easy to run) ---

# Maximum HTTP request body size accepted by the API, in bytes. Default is 65536.
# CHAT_REQUEST_BODY_LIMIT_BYTES=65536

# Runtime DTO limits for POST /api/chat. Defaults are generous for local demos.
# CHAT_MAX_MESSAGE_LENGTH=4000
# CHAT_MAX_SESSION_ID_LENGTH=128

# Optional server-side Bearer token gate. Leave unset for the no-key mock demo.
# When set, clients must send: Authorization: Bearer <token>
# API_BEARER_TOKEN=replace-with-local-demo-token

# In-memory rate limiting for the local/API process. Use Redis or gateway limits in production.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_IP_PER_WINDOW=120
# RATE_LIMIT_USER_PER_WINDOW=60
# RATE_LIMIT_SESSION_PER_WINDOW=30

# Real LLM concurrency semaphore. Mock mode does not consume these slots.
# LLM_MAX_CONCURRENT_REQUESTS=20
# LLM_MAX_CONCURRENT_REQUESTS_PER_SESSION=2

# In-memory session capacity controls. Production should replace this with Redis/Postgres.
# SESSION_TTL_MS=7200000
# SESSION_MAX_COUNT=1000
# SESSION_MAX_MESSAGES=40

# Web
VITE_API_BASE_URL=http://localhost:3000
