{
  "name": "mianshi-ai-chatbot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "concurrently -k \"pnpm --filter @mianshi/api dev\" \"pnpm --filter @mianshi/web dev\"",
    "build": "pnpm --filter @mianshi/api build && pnpm --filter @mianshi/web build",
    "test": "pnpm --filter @mianshi/api test",
    "check": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
